<Window x:Class="uroborus.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Uroborus" Height="660" Width="360"
        Icon="logo.ico"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen"
        PreviewKeyDown="Window_PreviewKeyDown" Focusable="True"
        MouseWheel="Window_MouseWheel"
        Drop="Window_Drop" DragOver="Window_DragOver" AllowDrop="True"
        UseLayoutRounding="True" 
        SnapsToDevicePixels="True" 
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto">

    <Window.Resources>
        <SolidColorBrush x:Key="MainBg"    Color="#0A0A0A"/>
        <SolidColorBrush x:Key="CardBg"    Color="#141414"/>
        <SolidColorBrush x:Key="CardBg2"   Color="#1E1E1E"/>
        <SolidColorBrush x:Key="TextMain"  Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSec"   Color="#555555"/>
        <SolidColorBrush x:Key="Accent"    Color="#E0115F"/>
        <SolidColorBrush x:Key="LogoColor" Color="#FFFFFF"/>

        <DrawingImage x:Key="TbPrev">
            <DrawingImage.Drawing>
                <GeometryDrawing Brush="White" Geometry="M 10,0 L 0,5 L 10,10 Z M 0,0 L -2,0 L -2,10 L 0,10 Z"/>
            </DrawingImage.Drawing>
        </DrawingImage>
        <DrawingImage x:Key="TbPlay">
            <DrawingImage.Drawing>
                <GeometryDrawing Brush="White" Geometry="M 0,0 L 10,5 L 0,10 Z"/>
            </DrawingImage.Drawing>
        </DrawingImage>
        <DrawingImage x:Key="TbPause">
            <DrawingImage.Drawing>
                <GeometryDrawing Brush="White" Geometry="M 0,0 L 3,0 L 3,10 L 0,10 Z M 6,0 L 9,0 L 9,10 L 6,10 Z"/>
            </DrawingImage.Drawing>
        </DrawingImage>
        <DrawingImage x:Key="TbNext">
            <DrawingImage.Drawing>
                <GeometryDrawing Brush="White" Geometry="M 0,0 L 10,5 L 0,10 Z M 10,0 L 12,0 L 12,10 L 10,10 Z"/>
            </DrawingImage.Drawing>
        </DrawingImage>

        <Style TargetType="ContextMenu" x:Key="ModernMenu">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Background"       Value="#0A0A0A"/>
            <Setter Property="BorderBrush"      Value="#18FFFFFF"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.5" Direction="270"/>
                            </Border.Effect>
                            <ItemsPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="MenuItem" x:Key="ModernMenuItem">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Foreground"       Value="#CCCCCC"/>
            <Setter Property="FontFamily"       Value="Segoe UI"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="Padding"          Value="14,8,24,8"/>
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8" Margin="0,1,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0" Content="{TemplateBinding Header}" Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="Arrow" Grid.Column="1" Text="›" FontSize="16" Foreground="#555555" VerticalAlignment="Center" Margin="0,0,10,0" Visibility="Collapsed"/>
                                <Popup x:Name="PART_Popup" AllowsTransparency="True" Placement="Right" PlacementTarget="{Binding ElementName=Bd}" IsOpen="{TemplateBinding IsSubmenuOpen}" Focusable="False">
                                    <Border Background="#0A0A0A" BorderBrush="#18FFFFFF" BorderThickness="1" CornerRadius="12" Padding="4" Margin="2,0,0,0">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.5" Direction="270"/>
                                        </Border.Effect>
                                        <ItemsPresenter/>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1AFFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="Role" Value="SubmenuHeader">
                                <Setter TargetName="Arrow" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Separator" x:Key="ModernSeparator">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Height="1" Background="#1FFFFFFF" Margin="8,3,8,3"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="IsMoveToPointEnabled" Value="True"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center" MinHeight="20">
                            <Border Height="3" Background="{StaticResource CardBg2}" CornerRadius="2" BorderBrush="#18FFFFFF" BorderThickness="1"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="3" Background="{StaticResource Accent}" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Grid Background="Transparent" Margin="-7,-10">
                                                    <Ellipse Width="13" Height="13" Fill="{StaticResource TextMain}">
                                                        <Ellipse.Effect>
                                                            <DropShadowEffect BlurRadius="6" ShadowDepth="0" Opacity="0.7" Color="#E0115F"/>
                                                        </Ellipse.Effect>
                                                    </Ellipse>
                                                </Grid>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource TextSec}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="5" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
                </Trigger>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.15" Duration="0:0:0.15">
                                <DoubleAnimation.EasingFunction>
                                    <QuadraticEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.15" Duration="0:0:0.15">
                                <DoubleAnimation.EasingFunction>
                                    <QuadraticEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.0" Duration="0:0:0.25">
                                <DoubleAnimation.EasingFunction>
                                    <QuadraticEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.0" Duration="0:0:0.25">
                                <DoubleAnimation.EasingFunction>
                                    <QuadraticEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SoftHoverBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSec}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="HoverBg" Background="#16FFFFFF" CornerRadius="8" Opacity="0"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverBg" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverBg" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.25"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MiniCrossBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource TextSec}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" Padding="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#E0115F"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GhostBtn" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource TextSec}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="BaseBorder" Background="Transparent" CornerRadius="8" Padding="10,5"/>
                            <Border x:Name="HoverBorder" Background="#1AFFFFFF" CornerRadius="8" Opacity="0"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverBorder" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverBorder" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.25"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="HoverBorder" Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PopupBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1AFFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TrashBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource TextSec}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="HoverBorder" Background="#22E0115F" CornerRadius="8" Opacity="0"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverBorder" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverBorder" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.25"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#E0115F"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AccentBtn" TargetType="Button">
            <Setter Property="Background" Value="#E0115F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="BaseBorder" Background="{TemplateBinding Background}" CornerRadius="18" Padding="13,6"/>
                            <Border x:Name="HoverBorder" Background="#C4104F" CornerRadius="18" Opacity="0"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="13,6"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverBorder" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverBorder" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.25"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CleanListBoxItem" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="Transparent">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="14"/>
            <Setter Property="Margin" Value="0,15,0,15"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="true" ViewportSize="NaN">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Height="50" Cursor="Hand">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Grid Background="Transparent">
                                                    <Border x:Name="ThumbBorder" Background="#4DFFFFFF" CornerRadius="3" Width="4" HorizontalAlignment="Right" Margin="0,0,4,0"/>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="#80FFFFFF"/>
                                                        <Setter TargetName="ThumbBorder" Property="Width" Value="6"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="#A0E0115F"/>
                                                        <Setter TargetName="ThumbBorder" Property="Width" Value="6"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Window.TaskbarItemInfo>
        <TaskbarItemInfo>
            <TaskbarItemInfo.ThumbButtonInfos>
                <ThumbButtonInfo x:Name="TaskbarPrevBtn" Description="Назад" ImageSource="{StaticResource TbPrev}" Click="TaskbarPrevBtn_Click"/>
                <ThumbButtonInfo x:Name="TaskbarPlayBtn" Description="Играть/Пауза" ImageSource="{StaticResource TbPlay}" Click="TaskbarPlayBtn_Click"/>
                <ThumbButtonInfo x:Name="TaskbarNextBtn" Description="Вперед" ImageSource="{StaticResource TbNext}" Click="TaskbarNextBtn_Click"/>
            </TaskbarItemInfo.ThumbButtonInfos>
        </TaskbarItemInfo>
    </Window.TaskbarItemInfo>

    <Border x:Name="RootBorder" Background="{StaticResource MainBg}" CornerRadius="26" BorderBrush="#13FFFFFF" BorderThickness="1.5" ClipToBounds="True">
        <Grid>
            <Grid x:Name="NormalModeGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="42"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="Header_Drag">
                    <TextBlock Text="U R O B O R U S" Foreground="{StaticResource LogoColor}" FontFamily="Segoe UI" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False" Margin="4,0,0,0"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="16,0,0,0">
                        <Button Style="{StaticResource IconBtn}" Click="HotkeysBtn_Click" ToolTip="Горячие клавиши (Esc)">
                            <TextBlock Text="⌨" FontSize="15"/>
                        </Button>
                        <Button x:Name="PlaylistsBtn" Style="{StaticResource IconBtn}" Click="PlaylistsBtn_Click" ToolTip="Плейлисты" Margin="8,0,0,0">
                            <TextBlock Text="☰" FontSize="15"/>
                        </Button>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0">
                        <Button Content="◳" Style="{StaticResource IconBtn}" Click="MiniPlayerBtn_Click" FontSize="14" FontWeight="Bold" Margin="0,0,4,0" ToolTip="Мини-плеер (Ctrl+M)"/>
                        <Button Content="↻"  Style="{StaticResource IconBtn}" Click="RefreshApp_Click" FontSize="14" FontWeight="Bold" Margin="0,0,4,0" ToolTip="Обновить плеер"/>
                        <Button Content="—"  Style="{StaticResource IconBtn}" Click="MinimizeBtn_Click" FontSize="12" FontWeight="Bold"/>
                        <Button Content="✕"  Style="{StaticResource IconBtn}" Click="CloseBtn_Click" FontSize="12"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" Margin="20,0,20,18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Width="180" Height="180" Margin="0,4,0,16" HorizontalAlignment="Center">
                        <Grid.Effect>
                            <DropShadowEffect BlurRadius="30" ShadowDepth="4" Opacity="0.4" Direction="270"/>
                        </Grid.Effect>

                        <Border x:Name="DefaultCoverLayer" Background="#0C0C0C" CornerRadius="16" BorderThickness="1" BorderBrush="#12FFFFFF">
                            <Grid>
                                <Rectangle RadiusX="16" RadiusY="16">
                                    <Rectangle.Fill>
                                        <RadialGradientBrush Center="0.5,0.5" RadiusX="0.8" RadiusY="0.8">
                                            <GradientStop Color="#1A1A1A" Offset="0"/>
                                            <GradientStop Color="#080808" Offset="1"/>
                                        </RadialGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>
                                <Path Data="M 12,3 L 12,15 A 3,3 0 1 0 15,18 L 15,7 L 21,7 L 21,3 Z" Fill="#2A2A2A" HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="Uniform" Width="40" Height="40" Margin="0,0,0,4"/>
                            </Grid>
                        </Border>

                        <Border x:Name="ImageCoverLayer" CornerRadius="16" Visibility="Collapsed" ClipToBounds="True">
                            <Border.Background>
                                <ImageBrush x:Name="CoverImageBrush" Stretch="UniformToFill"/>
                            </Border.Background>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1" HorizontalAlignment="Center" Width="220">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="26"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Canvas Grid.Row="0" ClipToBounds="True" Width="220" Height="26" SizeChanged="MarqueeContainer_SizeChanged">
                            <StackPanel x:Name="MarqueePanel" Orientation="Horizontal" Canvas.Left="0" Canvas.Top="2">
                                <TextBlock x:Name="TrackNameText" Text="No Track" Foreground="{StaticResource TextMain}" FontSize="18" FontWeight="Bold" FontFamily="Segoe UI"/>
                                <TextBlock x:Name="TrackNameTextClone" Text="" Foreground="{StaticResource TextMain}" FontSize="18" FontWeight="Bold" FontFamily="Segoe UI" Margin="40,0,0,0" Visibility="Collapsed"/>
                            </StackPanel>
                        </Canvas>

                        <TextBlock Grid.Row="1" x:Name="TrackSubText" Text="" Foreground="{StaticResource TextSec}" FontSize="13" FontFamily="Segoe UI" TextAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,13,0,0">
                        <Slider x:Name="ProgressSlider" Thumb.DragStarted="Seek_DragStart" Thumb.DragCompleted="Seek_DragEnd" PreviewMouseLeftButtonDown="Seek_MouseDown" PreviewMouseLeftButtonUp="Seek_MouseUp" Margin="0,0,0,13"/>
                        <Grid Margin="2,17,2,0" VerticalAlignment="Bottom">
                            <TextBlock x:Name="CurrentTimeText" Text="0:00" Foreground="{StaticResource TextSec}" FontSize="10" FontFamily="Consolas" HorizontalAlignment="Left"/>
                            <TextBlock x:Name="TotalTimeText" Text="0:00" Foreground="{StaticResource TextSec}" FontSize="10" FontFamily="Consolas" HorizontalAlignment="Right"/>
                        </Grid>
                    </Grid>

                    <Grid Grid.Row="3" Margin="0,10,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button x:Name="ShuffleBtn" Content="⇄" Style="{StaticResource IconBtn}" FontSize="16" Click="ShuffleBtn_Click" ToolTip="Случайный порядок (S)"/>
                            <Button x:Name="PrevBtn" Content="⏮" Style="{StaticResource IconBtn}" FontSize="22" Click="PrevBtn_Click" Margin="9,0,0,0" ToolTip="Назад (B)"/>

                            <Button x:Name="PlayPauseBtn" Click="PlayPauseBtn_Click" Margin="14,0,14,0" Width="54" Height="54" Cursor="Hand" ToolTip="Пробел" Focusable="False">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Grid x:Name="PlayGrid" RenderTransformOrigin="0.5,0.5">
                                            <Grid.RenderTransform>
                                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                                            </Grid.RenderTransform>
                                            <Ellipse Fill="{StaticResource Accent}" Opacity="0.93">
                                                <Ellipse.Effect>
                                                    <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.7" Color="#E0115F"/>
                                                </Ellipse.Effect>
                                            </Ellipse>
                                            <TextBlock x:Name="PlayIconInternal" Text="▶" Foreground="White" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="3,0,0,0"/>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <EventTrigger RoutedEvent="MouseEnter">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="PlayGrid" Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.08" Duration="0:0:0.15">
                                                            <DoubleAnimation.EasingFunction>
                                                                <QuadraticEase EasingMode="EaseOut"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <DoubleAnimation Storyboard.TargetName="PlayGrid" Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.08" Duration="0:0:0.15">
                                                            <DoubleAnimation.EasingFunction>
                                                                <QuadraticEase EasingMode="EaseOut"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                            <EventTrigger RoutedEvent="MouseLeave">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="PlayGrid" Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.0" Duration="0:0:0.25">
                                                            <DoubleAnimation.EasingFunction>
                                                                <QuadraticEase EasingMode="EaseOut"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <DoubleAnimation Storyboard.TargetName="PlayGrid" Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.0" Duration="0:0:0.25">
                                                            <DoubleAnimation.EasingFunction>
                                                                <QuadraticEase EasingMode="EaseOut"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button x:Name="NextBtn" Content="⏭" Style="{StaticResource IconBtn}" FontSize="22" Click="NextBtn_Click" Margin="0,0,9,0" ToolTip="Вперёд (N)"/>
                            <Button x:Name="LoopBtn" Content="↻" Style="{StaticResource IconBtn}" FontSize="16" Click="LoopBtn_Click" ToolTip="Повтор (R)"/>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="4" Margin="0,13,0,11">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="26"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="36"/>
                        </Grid.ColumnDefinitions>

                        <Button Style="{StaticResource IconBtn}" Click="VolIcon_Click" ToolTip="Громкость (M)" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock x:Name="VolIcon" Text="🔈" FontSize="13" Margin="0,-2,0,0"/>
                        </Button>

                        <Slider x:Name="VolumeSlider" Grid.Column="1" Minimum="0" Maximum="1" Value="0.5" ValueChanged="VolumeSlider_ValueChanged" VerticalAlignment="Center"/>
                        <TextBlock x:Name="VolPct" Grid.Column="2" Text="50%" Foreground="{StaticResource TextSec}" FontSize="10" FontFamily="Consolas" VerticalAlignment="Center" TextAlignment="Center"/>
                    </Grid>

                    <Grid Grid.Row="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="4,0,4,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Name="QueueLabel" Text="О Ч Е Р Е Д Ь" Foreground="{StaticResource TextSec}" FontSize="11" FontFamily="Segoe UI" FontWeight="Bold" VerticalAlignment="Center" MaxWidth="110" TextTrimming="CharacterEllipsis"/>
                                <Button Style="{StaticResource IconBtn}" FontSize="11" Margin="6,0,0,0" ToolTip="Предыдущий плейлист (PageUp)" Click="PrevPlaylist_Click">
                                    <TextBlock Text="⏮" Foreground="{StaticResource Accent}"/>
                                </Button>
                                <Button Style="{StaticResource IconBtn}" FontSize="11" Margin="2,0,0,0" ToolTip="Следующий плейлист (PageDown)" Click="NextPlaylist_Click">
                                    <TextBlock Text="⏭" Foreground="{StaticResource Accent}"/>
                                </Button>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button x:Name="ScrollToCurrentBtn" Style="{StaticResource IconBtn}" FontSize="12"
        Click="ScrollToCurrentBtn_Click" ToolTip="Перейти к текущему треку" Margin="0,0,4,0">
                                    <TextBlock Text="◎" FontSize="13"/>
                                </Button>
                                <Button x:Name="SearchToggleBtn" Style="{StaticResource IconBtn}" FontSize="12" Click="SearchToggleBtn_Click" ToolTip="Поиск (Ctrl+F)" Margin="0,0,4,0">
                                    <TextBlock Text="🔍" FontSize="11"/>
                                </Button>

                                <ToggleButton x:Name="AddBtnToggle" Style="{StaticResource GhostBtn}" Padding="10,5" Margin="0,0,4,0" ToolTip="Добавить (Ctrl+O)">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="+" FontSize="13" Margin="0,-2,4,0" VerticalAlignment="Center" Foreground="{StaticResource Accent}" FontWeight="Bold"/>
                                        <TextBlock Text="добавить" VerticalAlignment="Center" FontFamily="Segoe UI" FontSize="12" Foreground="{StaticResource TextSec}"/>
                                    </StackPanel>
                                </ToggleButton>

                                <Popup IsOpen="{Binding IsChecked, ElementName=AddBtnToggle, Mode=TwoWay}" PlacementTarget="{Binding ElementName=AddBtnToggle}" Placement="Bottom" StaysOpen="False" VerticalOffset="8" HorizontalOffset="-30" AllowsTransparency="True">
                                    <Border Background="#0A0A0A" BorderBrush="#18FFFFFF" BorderThickness="1" CornerRadius="12" Padding="6" Width="110">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.6" Direction="270"/>
                                        </Border.Effect>
                                        <StackPanel>
                                            <Button Content="🎵  файл" Style="{StaticResource PopupBtn}" Click="AddBtn_Click"/>
                                            <Button Content="📁  папку" Style="{StaticResource PopupBtn}" Click="AddFolderBtn_Click"/>
                                        </StackPanel>
                                    </Border>
                                </Popup>

                                <Button Style="{StaticResource TrashBtn}" Click="ClearQueue_Click" ToolTip="Очистить очередь">
                                    <TextBlock Text="🗑" FontSize="12"/>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <Border Grid.Row="1" x:Name="SearchBar" Background="{StaticResource CardBg2}" CornerRadius="12" Margin="0,0,0,6" Padding="12,0,8,0" Visibility="Collapsed" Height="36">
                            <Border.RenderTransform>
                                <TranslateTransform Y="-10" x:Name="SearchTranslate"/>
                            </Border.RenderTransform>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="🔍" FontSize="11" Foreground="{StaticResource TextSec}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox x:Name="SearchBoxCtrl" Grid.Column="1" Background="Transparent" Foreground="{StaticResource TextMain}" CaretBrush="{StaticResource Accent}" BorderThickness="0" FontFamily="Segoe UI" FontSize="13" VerticalAlignment="Center" TextChanged="SearchBox_TextChanged" KeyDown="SearchBox_KeyDown">
                                    <TextBox.Template>
                                        <ControlTemplate TargetType="TextBox">
                                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                        </ControlTemplate>
                                    </TextBox.Template>
                                </TextBox>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2" Background="{StaticResource CardBg}" CornerRadius="13" Padding="3" BorderBrush="#07FFFFFF" BorderThickness="1" MinHeight="55">
                            <Grid>
                                <TextBlock x:Name="QueueEmptyText" Text="ничего не найдено" Foreground="{StaticResource TextSec}" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" IsHitTestVisible="False" FontFamily="Segoe UI" FontSize="13"/>

                                <ListBox x:Name="QueueList" Background="Transparent" BorderThickness="0"
                                         AllowDrop="True" DragLeave="ListBox_DragLeave"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         VirtualizingStackPanel.IsVirtualizing="True"
                                         VirtualizingStackPanel.VirtualizationMode="Recycling"
                                         VirtualizingPanel.ScrollUnit="Pixel"
                                         VirtualizingPanel.CacheLengthUnit="Item"
                                         VirtualizingPanel.CacheLength="3,3"
                                         PreviewDragOver="ListBox_PreviewDragOver"
                                         ItemContainerStyle="{StaticResource CleanListBoxItem}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Background="Transparent" Margin="0,0,0,2" Cursor="Hand" MouseLeftButtonDown="Track_Click" MouseRightButtonUp="Track_MouseRightButtonUp" Tag="{Binding Path}">
                                                <Border Background="Transparent" CornerRadius="9" Padding="0,4" HorizontalAlignment="Stretch">
                                                    <Grid Height="30" AllowDrop="True" Drop="TrackItem_Drop" DragOver="TrackItem_DragOver" DragLeave="TrackItem_DragLeave" Background="Transparent">

                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="28"/>
                                                            <ColumnDefinition Width="32"/>
                                                            <ColumnDefinition Width="1*"/>
                                                            <ColumnDefinition Width="65"/>
                                                            <ColumnDefinition Width="38"/>
                                                            <ColumnDefinition Width="26"/>
                                                        </Grid.ColumnDefinitions>

                                                        <Border x:Name="TrackHover" Grid.ColumnSpan="6" Background="#0CFFFFFF" CornerRadius="9" Opacity="0" Margin="0,-4,0,-4"/>
                                                        <Border x:Name="TrackActive" Grid.ColumnSpan="6" Background="#12E0115F" CornerRadius="9" Opacity="0" Margin="0,-4,0,-4"/>

                                                        <Border x:Name="HandleZone" Grid.Column="0" Background="Transparent" Cursor="SizeNS" MouseLeftButtonDown="TrackHandle_MouseDown" MouseMove="TrackHandle_MouseMove" ToolTip="Перетащить для изменения порядка">
                                                            <TextBlock x:Name="Handle" Text="⠿" FontSize="14" Foreground="#286e6e6e" VerticalAlignment="Center" HorizontalAlignment="Center" IsHitTestVisible="False">
                                                                <TextBlock.RenderTransform>
                                                                    <TranslateTransform Y="1"/>
                                                                </TextBlock.RenderTransform>
                                                            </TextBlock>
                                                        </Border>

                                                        <Border x:Name="NumBorder" Grid.Column="1" Width="24" Height="24" CornerRadius="12" Background="#0AFFFFFF" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                            <TextBlock x:Name="NumText" Text="{Binding DisplayIndex}" Foreground="#888888" FontSize="11" FontWeight="Bold" FontFamily="Segoe UI" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,-1,0,0"/>
                                                        </Border>

                                                        <TextBlock x:Name="TitleText" Text="{Binding Title}" Grid.Column="2" Foreground="{StaticResource TextSec}" FontSize="13" FontFamily="Segoe UI" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="6,0,4,0"/>
                                                        <TextBlock Text="{Binding Info}" Grid.Column="3" Foreground="{StaticResource TextSec}" FontSize="11" FontFamily="Consolas" VerticalAlignment="Center" TextAlignment="Right" Margin="0,0,4,0"/>
                                                        <TextBlock x:Name="DurText" Text="{Binding Duration}" Grid.Column="4" Foreground="{StaticResource TextSec}" FontSize="13" FontFamily="Consolas" FontWeight="SemiBold" VerticalAlignment="Center" TextAlignment="Right" Margin="0,0,2,0"/>

                                                        <TextBlock x:Name="LikeGlyph" Text="♡" Grid.Column="5" FontSize="16" Foreground="#666666" VerticalAlignment="Center" HorizontalAlignment="Center" Cursor="Hand" Margin="0,0,2,0" MouseLeftButtonDown="TrackLike_Click" Tag="{Binding Path}">
                                                            <TextBlock.RenderTransform>
                                                                <TranslateTransform Y="1"/>
                                                            </TextBlock.RenderTransform>
                                                        </TextBlock>

                                                        <Border x:Name="DropLine" Grid.ColumnSpan="6" Height="2" VerticalAlignment="Top" Visibility="Collapsed" Margin="4,-5,4,0" CornerRadius="1">
                                                            <Border.Background>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                    <GradientStop Color="#00E0115F" Offset="0"/>
                                                                    <GradientStop Color="#E0115F" Offset="0.2"/>
                                                                    <GradientStop Color="#E0115F" Offset="0.8"/>
                                                                    <GradientStop Color="#00E0115F" Offset="1"/>
                                                                </LinearGradientBrush>
                                                            </Border.Background>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </Grid>

                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                    <Setter TargetName="TrackActive" Property="Opacity" Value="1"/>
                                                    <Setter TargetName="NumBorder" Property="Background" Value="#22E0115F"/>
                                                    <Setter TargetName="NumText" Property="Text" Value="▶"/>
                                                    <Setter TargetName="NumText" Property="Foreground" Value="{StaticResource Accent}"/>
                                                    <Setter TargetName="NumText" Property="FontSize" Value="12"/>
                                                    <Setter TargetName="TitleText" Property="Foreground" Value="{StaticResource TextMain}"/>
                                                    <Setter TargetName="TitleText" Property="FontWeight" Value="SemiBold"/>
                                                    <Setter TargetName="DurText" Property="Foreground" Value="{StaticResource Accent}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsLiked}" Value="True">
                                                    <Setter TargetName="LikeGlyph" Property="Text" Value="♥"/>
                                                    <Setter TargetName="LikeGlyph" Property="Foreground" Value="{StaticResource Accent}"/>
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Trigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetName="TrackHover" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </Trigger.EnterActions>
                                                    <Trigger.ExitActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetName="TrackHover" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.25"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </Trigger.ExitActions>
                                                    <Setter TargetName="Handle" Property="Foreground" Value="#AAb0b0b0"/>
                                                </Trigger>
                                                <DataTrigger Binding="{Binding IsDragging}" Value="True">
                                                    <Setter TargetName="TrackHover" Property="Background" Value="#18E0115F"/>
                                                    <Setter TargetName="TrackHover" Property="Opacity" Value="1"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <Border x:Name="DrawerOverlay" Grid.Row="0" Grid.RowSpan="2" Background="#88000000" Visibility="Collapsed" MouseLeftButtonDown="DrawerOverlay_Click" Panel.ZIndex="10"/>
                <Border x:Name="PlaylistDrawer" Grid.Row="0" Grid.RowSpan="2" Width="320" HorizontalAlignment="Left" Background="#050505" CornerRadius="0,20,20,0" Visibility="Collapsed" Panel.ZIndex="11" BorderThickness="0,0,1,0" BorderBrush="#18FFFFFF">
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="DrawerTranslate" X="-320"/>
                    </Border.RenderTransform>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="24,24,20,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="DrawerBackBtn" Content="←" Style="{StaticResource IconBtn}" HorizontalAlignment="Left" FontSize="18" FontWeight="Bold" Click="DrawerBack_Click" Visibility="Collapsed" Grid.Column="0" Margin="0,0,12,0"/>
                            <TextBlock x:Name="DrawerTitle" Text="М Е Д И А Т Е К А" Foreground="{StaticResource TextSec}" FontFamily="Segoe UI" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" Grid.Column="1"/>
                            <Button Content="✕" Style="{StaticResource IconBtn}" HorizontalAlignment="Right" FontSize="14" Click="DrawerClose_Click" Grid.Column="2"/>
                        </Grid>

                        <ScrollViewer x:Name="PlaylistListScroll" Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="14,0,6,0">
                            <StackPanel x:Name="PlaylistPanel" Margin="0,4,8,4"/>
                        </ScrollViewer>

                        <Grid x:Name="PlaylistDetailView" Grid.Row="1" Visibility="Collapsed" Margin="14,0,6,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,8,16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border x:Name="DetailPlIconBorder" Width="56" Height="56" CornerRadius="14" Margin="0,0,16,0" ClipToBounds="True"/>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock x:Name="DetailPlName" Foreground="{StaticResource TextMain}" FontFamily="Segoe UI" FontSize="20" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock x:Name="DetailPlCount" Foreground="{StaticResource TextSec}" FontFamily="Segoe UI" FontSize="13" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Grid.Row="1" Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Button x:Name="DetailPlayBtn" Grid.Column="0" Content="▶  слушать" Style="{StaticResource AccentBtn}" FontFamily="Segoe UI" FontSize="14" FontWeight="SemiBold" Click="DetailPlay_Click" Padding="14,8"/>

                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <ToggleButton x:Name="DetailAddBtnToggle" Style="{StaticResource GhostBtn}" Width="30" Height="30" Margin="0,0,2,0" ToolTip="Добавить треки">
                                            <TextBlock Text="+" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-2,0,0"/>
                                        </ToggleButton>
                                        <Popup IsOpen="{Binding IsChecked, ElementName=DetailAddBtnToggle, Mode=TwoWay}" PlacementTarget="{Binding ElementName=DetailAddBtnToggle}" Placement="Bottom" StaysOpen="False" VerticalOffset="8" HorizontalOffset="-30" AllowsTransparency="True">
                                            <Border Background="#0A0A0A" BorderBrush="#18FFFFFF" BorderThickness="1" CornerRadius="12" Padding="6" Width="110">
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.6" Direction="270"/>
                                                </Border.Effect>
                                                <StackPanel>
                                                    <Button Content="🎵  файл" Style="{StaticResource PopupBtn}" Click="DetailAddFile_Click"/>
                                                    <Button Content="📁  папку" Style="{StaticResource PopupBtn}" Click="DetailAddFolder_Click"/>
                                                </StackPanel>
                                            </Border>
                                        </Popup>

                                        <!-- Разделитель -->
                                        <Border Width="1" Height="16" Background="#1AFFFFFF" Margin="4,0,4,0" VerticalAlignment="Center"/>

                                        <!-- Поиск -->
                                        <Button x:Name="DetailSearchToggleBtn" Style="{StaticResource IconBtn}" FontSize="12"
            Click="DetailSearchToggleBtn_Click" ToolTip="Поиск в плейлисте" Margin="0,0,2,0"
            RenderTransformOrigin="0.5,0.5">
                                            <Button.RenderTransform>
                                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                                            </Button.RenderTransform>
                                            <TextBlock Text="🔍" FontSize="12"/>
                                        </Button>

                                        <!-- Настройки -->
                                        <Button x:Name="DetailRenameBtn" Style="{StaticResource IconBtn}" FontSize="13"
            Click="DetailRename_Click" ToolTip="Настройки плейлиста" Margin="0,0,2,0"
            RenderTransformOrigin="0.5,0.5">
                                            <Button.RenderTransform>
                                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                                            </Button.RenderTransform>
                                            <TextBlock Text="✎" FontSize="13"/>
                                        </Button>

                                        <!-- Разделитель перед деструктивными кнопками -->
                                        <Border Width="1" Height="16" Background="#1AFFFFFF" Margin="4,0,4,0" VerticalAlignment="Center"/>

                                        <!-- Очистить — с красной подсветкой при ховере -->
                                        <Button x:Name="DetailClearBtn" Style="{StaticResource TrashBtn}" FontSize="13" Width="30" Height="30"
            Click="DetailClearBtn_Click" ToolTip="Очистить все треки" Margin="0,0,2,0">
                                            <TextBlock Text="🧹" FontSize="13"/>
                                        </Button>

                                        <!-- Удалить плейлист -->
                                        <Button x:Name="DetailDeleteBtn" Style="{StaticResource TrashBtn}" FontSize="13" Width="30" Height="30"
            Click="DetailDelete_Click" ToolTip="Удалить плейлист">
                                            <TextBlock Text="🗑" FontSize="13"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>

                                <Border x:Name="DetailSearchBar" Grid.Row="2" Background="{StaticResource CardBg2}" CornerRadius="12" Margin="0,0,0,0" Padding="12,0,8,0" Visibility="Collapsed" Height="36">
                                    <Border.RenderTransform>
                                        <TranslateTransform Y="-10" x:Name="DetailSearchTranslate"/>
                                    </Border.RenderTransform>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="🔍" FontSize="11" Foreground="{StaticResource TextSec}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBox x:Name="DetailSearchBoxCtrl" Grid.Column="1" Background="Transparent" Foreground="{StaticResource TextMain}" CaretBrush="{StaticResource Accent}" BorderThickness="0" FontFamily="Segoe UI" FontSize="13" VerticalAlignment="Center" TextChanged="DetailSearchBox_TextChanged"/>
                                    </Grid>
                                </Border>
                            </Grid>

                            <Border Grid.Row="1" Background="#0C0C0C" CornerRadius="12" Padding="4" BorderBrush="#12FFFFFF" BorderThickness="1" Margin="0,0,8,0">
                                <Grid>
                                    <TextBlock x:Name="DetailEmptyText" Text="ничего не найдено" Foreground="{StaticResource TextSec}" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" IsHitTestVisible="False" FontFamily="Segoe UI" FontSize="13"/>

                                    <ListBox x:Name="DetailTrackList" Background="Transparent" BorderThickness="0"
                                             AllowDrop="True" DragLeave="ListBox_DragLeave"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                             VirtualizingStackPanel.IsVirtualizing="True"
                                             VirtualizingStackPanel.VirtualizationMode="Recycling"
                                             VirtualizingPanel.ScrollUnit="Pixel"
                                             VirtualizingPanel.CacheLengthUnit="Item"
                                             VirtualizingPanel.CacheLength="3,3"
                                             PreviewDragOver="ListBox_PreviewDragOver"
                                             ItemContainerStyle="{StaticResource CleanListBoxItem}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="Transparent" CornerRadius="9" Padding="0,4" Cursor="Hand" MouseLeftButtonDown="DetailTrack_Click" MouseRightButtonUp="DetailTrack_MouseRightButtonUp" Tag="{Binding Path}">
                                                    <Grid Height="30" AllowDrop="True" Drop="DetailTrackItem_Drop" DragOver="DetailTrackItem_DragOver" DragLeave="DetailTrackItem_DragLeave" Background="Transparent">

                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="28"/>
                                                            <ColumnDefinition Width="32"/>
                                                            <ColumnDefinition Width="1*"/>
                                                            <ColumnDefinition Width="65"/>
                                                            <ColumnDefinition Width="38"/>
                                                            <ColumnDefinition Width="26"/>
                                                        </Grid.ColumnDefinitions>

                                                        <Border x:Name="TrackHover" Grid.ColumnSpan="6" Background="#0EFFFFFF" CornerRadius="9" Opacity="0" Margin="0,-4,0,-4"/>

                                                        <Border x:Name="HandleZone" Grid.Column="0" Background="Transparent" Cursor="SizeNS" MouseLeftButtonDown="DetailTrackHandle_MouseDown" MouseMove="DetailTrackHandle_MouseMove" ToolTip="Перетащить для изменения порядка">
                                                            <TextBlock x:Name="Handle" Text="⠿" FontSize="14" Foreground="#286e6e6e" VerticalAlignment="Center" HorizontalAlignment="Center" IsHitTestVisible="False">
                                                                <TextBlock.RenderTransform>
                                                                    <TranslateTransform Y="1"/>
                                                                </TextBlock.RenderTransform>
                                                            </TextBlock>
                                                        </Border>

                                                        <Border Grid.Column="1" Width="24" Height="24" CornerRadius="12" Background="#0AFFFFFF" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                            <TextBlock Text="{Binding DisplayIndex}" Foreground="#888888" FontSize="11" FontWeight="Bold" FontFamily="Segoe UI" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,-1,0,0"/>
                                                        </Border>

                                                        <TextBlock Text="{Binding Title}" Grid.Column="2" Foreground="{StaticResource TextMain}" FontSize="13" FontFamily="Segoe UI" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="6,0,4,0"/>
                                                        <TextBlock Text="{Binding Info}" Grid.Column="3" Foreground="{StaticResource TextSec}" FontSize="11" FontFamily="Consolas" VerticalAlignment="Center" TextAlignment="Right" Margin="0,0,4,0"/>
                                                        <TextBlock Text="{Binding Duration}" Grid.Column="4" Foreground="{StaticResource TextSec}" FontSize="13" FontFamily="Consolas" FontWeight="SemiBold" VerticalAlignment="Center" TextAlignment="Right" Margin="0,0,2,0"/>

                                                        <Button x:Name="RmBtn" Content="✕" Grid.Column="5" FontSize="12" Cursor="Hand" Opacity="0" VerticalAlignment="Center" Style="{StaticResource MiniCrossBtn}" Click="DetailTrackRemove_Click" Tag="{Binding Path}"/>

                                                        <Border x:Name="DropLine" Grid.ColumnSpan="6" Height="2" VerticalAlignment="Top" Visibility="Collapsed" Margin="4,-5,4,0" CornerRadius="1">
                                                            <Border.Background>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                    <GradientStop Color="#00E0115F" Offset="0"/>
                                                                    <GradientStop Color="#E0115F" Offset="0.2"/>
                                                                    <GradientStop Color="#E0115F" Offset="0.8"/>
                                                                    <GradientStop Color="#00E0115F" Offset="1"/>
                                                                </LinearGradientBrush>
                                                            </Border.Background>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                                <DataTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Trigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="TrackHover" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15"/>
                                                                    <DoubleAnimation Storyboard.TargetName="RmBtn" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </Trigger.EnterActions>
                                                        <Trigger.ExitActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="TrackHover" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.25"/>
                                                                    <DoubleAnimation Storyboard.TargetName="RmBtn" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.25"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </Trigger.ExitActions>
                                                        <Setter TargetName="Handle" Property="Foreground" Value="#AAb0b0b0"/>
                                                    </Trigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="2" Margin="14,12,14,20">
                            <Button x:Name="NewPlaylistBtn" Cursor="Hand" HorizontalAlignment="Stretch" Focusable="False" Click="NewPlaylistBtn_Click" Background="Transparent" BorderThickness="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Grid>
                                            <Border x:Name="HoverBorder" Background="#141414" CornerRadius="8" Opacity="0"/>
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="12,10"/>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <EventTrigger RoutedEvent="MouseEnter">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="HoverBorder" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                            <EventTrigger RoutedEvent="MouseLeave">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="HoverBorder" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.25"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="+" Foreground="{StaticResource TextSec}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,-2,8,0"/>
                                    <TextBlock Text="создать плейлист" FontFamily="Segoe UI" FontSize="13" Foreground="{StaticResource TextSec}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>

                <Border x:Name="HotkeysOverlay" Grid.Row="0" Grid.RowSpan="2" Background="#F00A0A0A" Visibility="Collapsed" MouseLeftButtonDown="HotkeysOverlay_Click" Panel.ZIndex="20" CornerRadius="26">
                    <Border HorizontalAlignment="Center" VerticalAlignment="Center" Background="#141414" CornerRadius="16" Padding="24" BorderBrush="#28FFFFFF" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="К О М Б И Н А Ц И И" Foreground="{StaticResource TextSec}" FontFamily="Segoe UI" FontSize="12" FontWeight="Bold" Margin="0,0,0,16" HorizontalAlignment="Center"/>

                            <StackPanel Grid.Row="1">
                                <StackPanel.Resources>
                                    <Style TargetType="Grid">
                                        <Setter Property="Margin" Value="0,0,0,12"/>
                                    </Style>
                                    <Style TargetType="TextBlock" x:Key="KeyText">
                                        <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                                        <Setter Property="FontFamily" Value="Consolas"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="FontSize" Value="13"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                    <Style TargetType="TextBlock" x:Key="DescText">
                                        <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
                                        <Setter Property="FontFamily" Value="Segoe UI"/>
                                        <Setter Property="FontSize" Value="14"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Margin" Value="16,0,0,0"/>
                                    </Style>
                                </StackPanel.Resources>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="65"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource KeyText}" Text="Space" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Column="1" Style="{StaticResource DescText}" Text="Пауза / Плей"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="65"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource KeyText}" Text="← / →" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Column="1" Style="{StaticResource DescText}" Text="Перемотка ±5 сек"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="65"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource KeyText}" Text="↑ / ↓" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Column="1" Style="{StaticResource DescText}" Text="Громкость"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="65"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource KeyText}" Text="PgUp/Dn" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Column="1" Style="{StaticResource DescText}" Text="Пред/След плейлист"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="65"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource KeyText}" Text="N / B" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Column="1" Style="{StaticResource DescText}" Text="След / Пред трек"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="65"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource KeyText}" Text="S / R" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Column="1" Style="{StaticResource DescText}" Text="Шафл / Повтор"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="65"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource KeyText}" Text="M" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Column="1" Style="{StaticResource DescText}" Text="Мут (без звука)"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="65"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource KeyText}" Text="L" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Column="1" Style="{StaticResource DescText}" Text="Любимый трек"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="65"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource KeyText}" Text="Ctrl+M" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Column="1" Style="{StaticResource DescText}" Text="Мини-плеер"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="65"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource KeyText}" Text="Ctrl+O" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Column="1" Style="{StaticResource DescText}" Text="Добавить файлы"/>
                                </Grid>
                                <Grid Margin="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="65"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource KeyText}" Text="Ctrl+F" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Column="1" Style="{StaticResource DescText}" Text="Поиск"/>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Border>
            </Grid>

            <Grid x:Name="MiniModeGrid" Visibility="Collapsed" Background="Transparent" MouseLeftButtonDown="Header_Drag">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="84"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Margin="12" Width="60" Height="60">
                        <Border x:Name="MiniDefaultCoverLayer" Background="#0C0C0C" CornerRadius="10" BorderThickness="1" BorderBrush="#12FFFFFF">
                            <Path Data="M 12,3 L 12,15 A 3,3 0 1 0 15,18 L 15,7 L 21,7 L 21,3 Z" Fill="#2A2A2A" HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="Uniform" Width="24" Height="24"/>
                        </Border>
                        <Border x:Name="MiniImageCoverLayer" CornerRadius="10" Visibility="Collapsed" ClipToBounds="True">
                            <Border.Background>
                                <ImageBrush x:Name="MiniCoverImageBrush" Stretch="UniformToFill"/>
                            </Border.Background>
                        </Border>
                    </Grid>

                    <Grid Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Canvas Grid.Row="0" ClipToBounds="True" Height="20" SizeChanged="MiniMarqueeContainer_SizeChanged">
                            <StackPanel x:Name="MiniMarqueePanel" Orientation="Horizontal" Canvas.Left="0" Canvas.Top="0">
                                <TextBlock x:Name="MiniTrackNameText" Text="No Track" Foreground="{StaticResource TextMain}" FontSize="14" FontWeight="Bold" FontFamily="Segoe UI"/>
                                <TextBlock x:Name="MiniTrackNameTextClone" Text="" Foreground="{StaticResource TextMain}" FontSize="14" FontWeight="Bold" FontFamily="Segoe UI" Margin="40,0,0,0" Visibility="Collapsed"/>
                            </StackPanel>
                        </Canvas>

                        <TextBlock Grid.Row="1" x:Name="MiniTrackSubText" Text="" Foreground="{StaticResource TextSec}" FontSize="11" FontFamily="Segoe UI" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                    </Grid>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,12,0">
                        <Button Content="⏮" Style="{StaticResource IconBtn}" FontSize="16" Click="PrevBtn_Click" Margin="0,0,4,0" ToolTip="Назад"/>

                        <Button x:Name="MiniPlayPauseBtn" Click="PlayPauseBtn_Click" Margin="0,0,4,0" Width="36" Height="36" Cursor="Hand" Focusable="False">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid RenderTransformOrigin="0.5,0.5">
                                        <Ellipse Fill="{StaticResource Accent}"/>
                                        <TextBlock x:Name="MiniPlayIconInternal" Text="▶" Foreground="White" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2,0,0,0"/>
                                    </Grid>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Content="⏭" Style="{StaticResource IconBtn}" FontSize="16" Click="NextBtn_Click" Margin="0,0,4,0" ToolTip="Вперёд"/>
                        <Button Content="⤢" Style="{StaticResource IconBtn}" FontSize="16" Click="MiniPlayerBtn_Click" ToolTip="Развернуть (Ctrl+M)" Margin="2,0,0,0"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" Margin="14,0,14,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="32"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="32"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="MiniCurrentTimeText" Grid.Column="0" Text="0:00" Foreground="{StaticResource TextSec}" FontSize="10" FontFamily="Consolas" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <Slider x:Name="MiniProgressSlider" Grid.Column="1" VerticalAlignment="Center" Margin="6,0,6,0"
                            Thumb.DragStarted="Seek_DragStart" Thumb.DragCompleted="Seek_DragEnd"
                            PreviewMouseLeftButtonDown="Seek_MouseDown" PreviewMouseLeftButtonUp="Seek_MouseUp"/>
                    <TextBlock x:Name="MiniTotalTimeText" Grid.Column="2" Text="0:00" Foreground="{StaticResource TextSec}" FontSize="10" FontFamily="Consolas" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </Grid>
            </Grid>

            <Border x:Name="LoadingPill" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,40"
                    Background="#1A1A1A" BorderBrush="#18FFFFFF" BorderThickness="1" CornerRadius="18"
                    Padding="16,12" Visibility="Collapsed" Panel.ZIndex="999" Opacity="0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="25" ShadowDepth="5" Opacity="0.6" Direction="270"/>
                </Border.Effect>
                <Border.RenderTransform>
                    <TranslateTransform x:Name="LoadingPillTranslate" Y="20"/>
                </Border.RenderTransform>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Grid Width="16" Height="16" Margin="0,0,10,0" RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <RotateTransform x:Name="LoadingSpinnerTransform" Angle="0"/>
                        </Grid.RenderTransform>
                        <Ellipse Stroke="#2A2A2A" StrokeThickness="2"/>
                        <Path Data="M 8,1 A 7,7 0 0 1 15,8" Stroke="{StaticResource Accent}" StrokeThickness="2" StrokeEndLineCap="Round"/>
                    </Grid>
                    <TextBlock x:Name="LoadingText" Text="Загрузка..." Foreground="{StaticResource TextMain}" 
                               FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

        </Grid>
    </Border>
</Window>